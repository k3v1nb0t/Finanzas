{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "groupId": { "type": "string", "description": "The ID of the budget group the user belongs to" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "status": { "type": "string", "enum": ["active", "blocked"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "groupId", "role", "status"]
    },
    "Group": {
      "title": "Group",
      "description": "A budget group (family or individual)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "ownerId": { "type": "string" },
        "members": { "type": "array", "items": { "type": "string" } },
        "inviteCode": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "active"] },
        "budget": { "type": "number", "description": "Monthly budget for the group" },
        "categoryBudgets": { 
          "type": "object", 
          "additionalProperties": { "type": "number" },
          "description": "Monthly budget per category" 
        },
        "customCategories": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Custom expense categories for the group"
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "ownerId", "inviteCode", "status"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A single income or expense record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "groupId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["groupId", "userId", "amount", "type", "category", "date"]
    },
    "RecurringExpense": {
      "title": "Recurring Expense",
      "description": "Template for monthly recurring expenses",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "groupId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "dayOfMonth": { "type": "number" },
        "paymentMethod": { "type": "string", "enum": ["Efectivo", "Tarjeta", "Transferencia", "Otros"] },
        "active": { "type": "boolean" },
        "endDate": { "type": "string", "format": "date", "description": "YYYY-MM-DD" },
        "status": { "type": "string", "enum": ["active", "finished"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "groupId", "amount", "category", "dayOfMonth", "paymentMethod"]
    },
    "SavingsGoal": {
      "title": "Savings Goal",
      "description": "A financial goal to save money",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "groupId": { "type": "string" },
        "name": { "type": "string" },
        "targetAmount": { "type": "number" },
        "currentAmount": { "type": "number" },
        "deadline": { "type": "string", "format": "date" },
        "icon": { "type": "string" },
        "color": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "groupId", "name", "targetAmount", "currentAmount"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/groups/{groupId}": {
      "schema": "Group",
      "description": "Budget groups"
    },
    "/groups/{groupId}/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Transactions within a group"
    },
    "/groups/{groupId}/recurringExpenses/{expenseId}": {
      "schema": "RecurringExpense",
      "description": "Monthly recurring expenses templates"
    },
    "/groups/{groupId}/savingsGoals/{goalId}": {
      "schema": "SavingsGoal",
      "description": "Savings goals within a group"
    },
    "/notifications/{notificationId}": {
      "schema": "object",
      "description": "System notifications"
    }
  }
}
